---
import Card from "@/components/ui/card.astro"
import CardContent from "@/components/ui/card-content.astro"
import Badge from "@/components/ui/badge.astro"
import { Calendar } from "lucide-astro"
import { DocumentRenderer } from '@keystatic/core/renderer'

interface Experience {
  company: string
  location: string
  position: string
  jobType: string
  startDate: string | null
  endDate: string | null
  stillWorking: boolean
  descriptionBullets?: readonly string[]
  content?: any
}

interface Props {
  workExperience: Array<{ slug: string; entry: Experience }>
}

const { workExperience } = Astro.props as Props

function formatRange(experience: Experience) {
  const start = experience.startDate
    ? new Date(experience.startDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
    : ''
  const end = experience.stillWorking
    ? 'Present'
    : experience.endDate
      ? new Date(experience.endDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
      : 'Present'
  return `${start} - ${end}`
}
---

<section id="experience" class="py-20">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto mb-16 text-center fade-in">
      <h2 class="text-3xl font-bold mb-4">Work Experience</h2>
      <div class="h-1 w-20 bg-primary mx-auto mb-8"></div>
      <p class="text-lg text-muted-foreground">My professional journey and career highlights</p>
    </div>

    <div class="max-w-4xl mx-auto">
      <div class="relative">
        <!-- Timeline Line -->
        <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-border"></div>
        
        <div class="space-y-8">
          {workExperience.map((experience, index) => (
            <div class="relative slide-up" style={`animation-delay: ${index * 0.1}s;`}>
              <!-- Timeline Dot -->
              <div class="absolute left-3 w-6 h-6 bg-primary rounded-full border-4 border-background shadow-sm z-10"></div>
              
              <!-- Content -->
              <div class="ml-16">
                <Card class="bg-card/50 backdrop-blur-sm border-border/50 hover:bg-card/70 transition-all duration-300">
                  <CardContent class="p-6">
                    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between mb-4">
                      <div class="mb-3 lg:mb-0">
                        <h3 class="text-xl font-semibold text-foreground mb-1">{experience.entry.position}</h3>
                        <p class="text-lg font-medium text-primary mb-1">{experience.entry.company}</p>
                        {experience.entry.location && <p class="text-sm text-muted-foreground">{experience.entry.location}</p>}
                      </div>
                      <div class="flex flex-col items-start lg:items-end space-y-2">
                        <div class="flex items-center text-sm text-muted-foreground bg-muted/50 px-3 py-1 rounded-full">
                          <Calendar class="h-4 w-4 mr-2" />
                          {formatRange(experience.entry)}
                        </div>
                        {experience.entry.jobType && (
                          <Badge variant="secondary" class="text-xs">
                            {experience.entry.jobType}
                          </Badge>
                        )}
                      </div>
                    </div>
                    
                    <div class="prose prose-sm dark:prose-invert max-w-none text-muted-foreground">
                      {experience.entry.content
                        ? <DocumentRenderer document={experience.entry.content} />
                        : experience.entry.descriptionBullets?.map((responsibility) => (
                            <div class="flex items-start gap-3 mb-2">
                              <div class="w-2 h-2 rounded-full bg-primary shrink-0 mt-2"></div>
                              <p class="text-sm text-muted-foreground leading-relaxed">{responsibility}</p>
                            </div>
                          ))
                      }
                    </div>
                  </CardContent>
                </Card>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>