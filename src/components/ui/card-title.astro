---
import { cn } from "@/lib/utils"

export interface Props {
  class?: string
  as?: string
}

const { class: className, as: element = "div", ...props } = Astro.props
const Element = element
---

<Element
  class={cn(
    "text-2xl font-semibold leading-none tracking-tight",
    className
  )}
  {...props}
>
  <slot />
</Element>