---
import Card from "@/components/ui/card.astro"
import CardContent from "@/components/ui/card-content.astro"
import CardHeader from "@/components/ui/card-header.astro"
import CardTitle from "@/components/ui/card-title.astro"
import CardDescription from "@/components/ui/card-description.astro"
import Badge from "@/components/ui/badge.astro"
import { ArrowRight } from "lucide-astro"

interface Project {
  name: string
  image: string | null
  shortDescription: string
  content: any
  techstack: readonly string[]
  experience: string | null
}

interface Props {
  projects: Array<{ slug: string; entry: Project }>
  workExperience: Array<{ slug: string; entry: { company: string } }>
}

const { projects, workExperience } = Astro.props as Props

function getExperienceCompany(slug: string | null) {
  if (!slug) return null;
  return workExperience.find(exp => exp.slug === slug)?.entry.company || slug;
}

// Show only first 3 projects on homepage
const displayProjects = projects.slice(0, 3);
---


<section id="projects" class="py-20">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto mb-16 text-center fade-in">
      <h2 class="text-3xl font-bold mb-4">Featured Projects</h2>
      <div class="h-1 w-20 bg-primary mx-auto mb-8"></div>
      <p class="text-lg text-muted-foreground">A showcase of my recent work and contributions</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto">
      {displayProjects.map((project, index) => (
        <a href={`/projects/${project.slug}`} class="slide-up block group" style={`animation-delay: ${index * 0.1}s;`}>
          <Card class="h-full bg-card/50 backdrop-blur-sm border-border/50 hover:bg-card/70 transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
            <CardHeader class="p-0">
              <div class="relative overflow-hidden rounded-t-lg">
                {project.entry.image ? (
                  <img
                    src={project.entry.image}
                    alt={project.entry.name}
                    class="w-full h-48 object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-48 bg-gradient-to-br from-primary/20 via-muted to-background"></div>
                )}
              </div>
            </CardHeader>
            
            <CardContent class="p-6">
              <CardTitle class="mb-2 text-foreground group-hover:text-primary transition-colors">{project.entry.name}</CardTitle>
              <CardDescription class="mb-4 text-sm leading-relaxed">
                {project.entry.shortDescription}
              </CardDescription>
              
              <div class="flex flex-wrap gap-2 mb-4">
                {project.entry.techstack.map((tech) => (
                  <Badge variant="outline" class="text-xs">
                    {tech}
                  </Badge>
                ))}
              </div>

              {project.entry.experience && (
                <div class="text-xs text-muted-foreground bg-muted/40 px-3 py-1.5 rounded border border-border/30 inline-block w-full">
                  💼 Dibuat saat bekerja di: <span class="font-medium text-foreground">{
                    getExperienceCompany(project.entry.experience)
                  }</span>
                </div>
              )}
            </CardContent>
          </Card>
        </a>
      ))}
    </div>

    {projects.length > 3 && (
      <div class="text-center mt-12 fade-in">
        <a
          href="/projects"
          class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-primary-foreground rounded-lg font-medium hover:bg-primary/90 transition-all duration-300 hover:gap-3"
        >
          View All Projects
          <ArrowRight class="h-4 w-4" />
        </a>
      </div>
    )}
  </div>
</section>