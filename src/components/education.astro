---
import Card from "@/components/ui/card.astro"
import CardContent from "@/components/ui/card-content.astro"
import { GraduationCap, Calendar } from "lucide-astro"
import { DocumentRenderer } from '@keystatic/core/renderer'

interface Education {
  campus: string
  degree: string
  startDate: string | null
  endDate: string | null
  descriptionBullets?: readonly string[]
  content?: any
}

interface Props {
  education: Array<{ slug: string; entry: Education }>
}

const { education } = Astro.props as Props

function formatRange(item: Education) {
  const start = item.startDate
    ? new Date(item.startDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
    : ''
  const end = item.endDate
    ? new Date(item.endDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
    : 'Present'
  return `${start} - ${end}`
}
---

<section id="education" class="py-20 bg-muted/30">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto mb-16 text-center fade-in">
      <h2 class="text-3xl font-bold mb-4">Education</h2>
      <div class="h-1 w-20 bg-primary mx-auto mb-8"></div>
      <p class="text-lg text-muted-foreground">My educational background and achievements</p>
    </div>

    <div class="max-w-4xl mx-auto space-y-6">
      {education.map((educationItem, index) => (
        <div class="slide-up" style={`animation-delay: ${index * 0.2}s;`}>
          <Card class="bg-card/50 backdrop-blur-sm border-border/50 hover:bg-card/70 transition-all duration-300">
            <CardContent class="p-6">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-4">
                <div class="flex items-start gap-4 mb-4 md:mb-0">
                  <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                    <GraduationCap class="h-6 w-6 text-primary" />
                  </div>
                  <div>
                    <h3 class="text-xl font-semibold text-foreground">{educationItem.entry.degree}</h3>
                    <p class="text-base text-foreground">{educationItem.entry.campus}</p>
                  </div>
                </div>
                <div class="flex flex-col items-start md:items-end space-y-2">
                  <div class="flex items-center text-sm text-muted-foreground">
                    <Calendar class="h-4 w-4 mr-1" />
                    {formatRange(educationItem.entry)}
                  </div>
                </div>
              </div>
              
              <div class="prose prose-sm dark:prose-invert max-w-none text-muted-foreground">
                {educationItem.entry.content
                  ? <DocumentRenderer document={educationItem.entry.content} />
                  : educationItem.entry.descriptionBullets?.map((bullet) => (
                      <div class="flex items-start gap-3 mb-2">
                        <div class="w-2 h-2 rounded-full bg-primary shrink-0 mt-2"></div>
                        <p class="text-sm text-muted-foreground leading-relaxed">{bullet}</p>
                      </div>
                    ))
                }
              </div>
            </CardContent>
          </Card>
        </div>
      ))}
    </div>
  </div>
</section>