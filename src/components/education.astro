---
import Card from "@/components/ui/card.astro"
import CardContent from "@/components/ui/card-content.astro"
import Badge from "@/components/ui/badge.astro"
import { GraduationCap, Calendar } from "lucide-astro"

interface Education {
  institution: string
  degree: string
  field: string
  location: string
  period: string
  grade?: string
  description?: string
}

const educations: Education[] = [
  {
    institution: "Sebelas Maret University",
    degree: "Bachelor's Degree",
    field: "Informatics Engineering",
    location: "Surakarta",
    period: "2019 - 2023",
    grade: "GPA: 3.64",
    description: "Focused on software engineering, database systems, and web development. Completed various projects including machine learning applications and web-based systems."
  },
  {
    institution: "SMA Negeri 3 Surakarta",
    degree: "High School Diploma",
    field: "Science",
    location: "Surakarta",
    period: "2016 - 2019",
    description: "Specialized in Mathematics and Natural Sciences with focus on Physics, Chemistry, and Mathematics."
  }
]
---

<section id="education" class="py-20 bg-muted/30">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto mb-16 text-center fade-in">
      <h2 class="text-3xl font-bold mb-4">Education</h2>
      <div class="h-1 w-20 bg-primary mx-auto mb-8"></div>
      <p class="text-lg text-muted-foreground">My educational background and achievements</p>
    </div>

    <div class="max-w-4xl mx-auto space-y-6">
      {educations.map((education, index) => (
        <div class="slide-up" style={`animation-delay: ${index * 0.2}s;`}>
          <Card class="bg-card/50 backdrop-blur-sm border-border/50 hover:bg-card/70 transition-all duration-300">
            <CardContent class="p-6">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-4">
                <div class="flex items-start gap-4 mb-4 md:mb-0">
                  <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                    <GraduationCap class="h-6 w-6 text-primary" />
                  </div>
                  <div>
                    <h3 class="text-xl font-semibold text-foreground">{education.degree}</h3>
                    <p class="text-lg font-medium text-primary">{education.field}</p>
                    <p class="text-base text-foreground">{education.institution}</p>
                    <p class="text-sm text-muted-foreground">{education.location}</p>
                  </div>
                </div>
                <div class="flex flex-col items-start md:items-end space-y-2">
                  <div class="flex items-center text-sm text-muted-foreground">
                    <Calendar class="h-4 w-4 mr-1" />
                    {education.period}
                  </div>
                  {education.grade && (
                    <Badge variant="secondary" class="text-xs">
                      {education.grade}
                    </Badge>
                  )}
                </div>
              </div>
              
              {education.description && (
                <p class="text-sm text-muted-foreground leading-relaxed mt-4">
                  {education.description}
                </p>
              )}
            </CardContent>
          </Card>
        </div>
      ))}
    </div>
  </div>
</section>