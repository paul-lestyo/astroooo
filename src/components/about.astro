---
import Card from "@/components/ui/card.astro"
import CardContent from "@/components/ui/card-content.astro"
import { Phone, Mail, MapPin } from "lucide-astro"

interface Props {
  about: {
    headline: string
    phone: string
    email: string
    location: string
  }
}

const { about } = Astro.props as Props
---

<section id="about" class="py-20 bg-muted/30">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto mb-16 text-center fade-in">
      <h2 class="text-3xl font-bold mb-4">About Me</h2>
      <div class="h-1 w-20 bg-primary mx-auto mb-8"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <div class="md:col-span-2 slide-up">
        <p class="text-lg mb-6">
          {about.headline}
        </p>
      </div>

      <div class="slide-up" style="animation-delay: 0.2s;">
        <Card>
          <CardContent class="pt-6">
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <Phone class="h-5 w-5 text-primary shrink-0 mt-0.5" />
                <div>
                  <p class="font-medium">Phone</p>
                  <p class="text-sm text-muted-foreground">{about.phone}</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <Mail class="h-5 w-5 text-primary shrink-0 mt-0.5" />
                <div>
                  <p class="font-medium">Email</p>
                  <p class="text-sm text-muted-foreground">{about.email}</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <MapPin class="h-5 w-5 text-primary shrink-0 mt-0.5" />
                <div>
                  <p class="font-medium">Location</p>
                  <p class="text-sm text-muted-foreground">{about.location}</p>
                </div>
              </li>
            </ul>
          </CardContent>
        </Card>
      </div>
    </div>
  </div>
</section>