---
import { Github, Linkedin, Mail } from "lucide-astro"
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

interface Props {
  contactInfo?: {
    email: string
    linkedin: string | null
    github: string | null
  }
}

const { contactInfo: propContactInfo } = Astro.props as Props

// If contactInfo not passed as prop, fetch it directly
let contactInfo = propContactInfo;
if (!contactInfo) {
  const reader = createReader(process.cwd(), keystaticConfig);
  contactInfo = await reader.singletons.contactInfo.readOrThrow();
}
---

<footer class="border-t py-8">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-center">
      <div class="mb-4 md:mb-0">
        <p class="text-sm text-muted-foreground">
          &copy; {new Date().getFullYear()} Paulus Lestyo Adhiatma. All rights reserved.
        </p>
      </div>
      <div class="flex items-center space-x-4">
        {contactInfo.github && (
          <a
            href={contactInfo.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-primary transition-colors"
            aria-label="GitHub"
          >
            <Github class="h-5 w-5" />
            <span class="sr-only">GitHub</span>
          </a>
        )}
        {contactInfo.linkedin && (
          <a
            href={contactInfo.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-primary transition-colors"
            aria-label="LinkedIn"
          >
            <Linkedin class="h-5 w-5" />
            <span class="sr-only">LinkedIn</span>
          </a>
        )}
        <a
          href={`mailto:${contactInfo.email}`}
          class="text-muted-foreground hover:text-primary transition-colors"
          aria-label="Email"
        >
          <Mail class="h-5 w-5" />
          <span class="sr-only">Email</span>
        </a>
      </div>
    </div>
  </div>
</footer>