---
import Layout from "@/layouts/Layout.astro"
import Hero from "@/components/hero.astro"
import About from "@/components/about.astro"
import Skills from "@/components/skills.astro"
import Experience from "@/components/experience.astro"
import Education from "@/components/education.astro"
import Projects from "@/components/projects.astro"
import Contact from "@/components/contact.astro"
import Footer from "@/components/footer.astro"
import { getPortfolioData } from "@/lib/portfolio"

const portfolio = await getPortfolioData()
---

<Layout>
  <Hero contact={portfolio.contactInfo} />
  <About about={portfolio.about} />
  <Skills technicalSkills={portfolio.technicalSkills} softSkills={portfolio.softSkills} />
  <Experience workExperience={portfolio.workExperience} />
  <Education education={portfolio.education} />
  <Projects projects={portfolio.projects} />
  <Contact contactInfo={portfolio.contactInfo} />
  <Footer contactInfo={portfolio.contactInfo} />
</Layout>