---
import Layout from "@/layouts/Layout.astro"
import Badge from "@/components/ui/badge.astro"
import Footer from "@/components/footer.astro"
import { DocumentRenderer } from '@keystatic/core/renderer'
import { getBlogPost, getBlogPosts } from "@/lib/portfolio"
import { ArrowLeft, Calendar } from "lucide-astro"
import { Image } from "astro:assets"

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map(post => ({
    params: { slug: post.slug }
  }));
}

const { slug } = Astro.params;
const data = await getBlogPost(slug!);

if (!data) {
  return Astro.redirect('/blog');
}

const { entry } = data;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": entry.title,
  "description": entry.excerpt,
  "datePublished": entry.publishDate,
  "image": entry.coverImage ? new URL(entry.coverImage, Astro.url.origin).toString() : undefined,
  "author": {
    "@type": "Person",
    "name": "Paulus Lestyo Adhiatma"
  }
};

function formatDate(dateStr: string | null) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
}
---

<Layout 
  title={`${entry.title} | Blog | Paulus Lestyo Adhiatma`}
  description={entry.excerpt || `Read ${entry.title} on Paulus Lestyo Adhiatma's blog.`}
  ogImage={entry.coverImage || undefined}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(blogPostingSchema)} />
  <article class="pt-28 pb-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <!-- Back Navigation -->
        <a href="/blog" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors mb-8">
          <ArrowLeft class="h-4 w-4" />
          Back to Blog
        </a>

        <!-- Cover Image -->
        {entry.coverImage && (
          <div class="relative overflow-hidden rounded-xl mb-8 shadow-lg">
            <Image
              src={entry.coverImage}
              alt={entry.title}
              width={1200}
              height={600}
              class="w-full h-64 md:h-96 object-cover"
            />
          </div>
        )}

        <!-- Header -->
        <header class="mb-8 border-b border-border/50 pb-8">
          <h1 class="text-3xl md:text-4xl font-bold mb-4">{entry.title}</h1>
          
          {entry.publishDate && (
            <div class="flex items-center text-sm text-muted-foreground mb-4">
              <Calendar class="h-4 w-4 mr-2" />
              {formatDate(entry.publishDate)}
            </div>
          )}

          {entry.excerpt && (
            <p class="text-lg text-muted-foreground italic">{entry.excerpt}</p>
          )}

          {entry.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {entry.tags.map((tag) => (
                <Badge variant="outline">{tag}</Badge>
              ))}
            </div>
          )}
        </header>

        <!-- Content -->
        <div class="prose prose-lg dark:prose-invert max-w-none text-muted-foreground">
          <DocumentRenderer document={entry.content} />
        </div>
      </div>
    </div>
  </article>
  <Footer />
</Layout>
