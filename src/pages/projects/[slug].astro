---
import Layout from "@/layouts/Layout.astro"
import Badge from "@/components/ui/badge.astro"
import Footer from "@/components/footer.astro"
import { DocumentRenderer } from '@keystatic/core/renderer'
import { getProject } from "@/lib/portfolio"
import { ArrowLeft, Calendar } from "lucide-astro"
import { Image } from "astro:assets"

const { slug } = Astro.params;
const data = await getProject(slug!);

if (!data) {
  return Astro.redirect('/projects');
}

const { entry, workExperience } = data;

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": entry.name,
  "description": entry.shortDescription,
  "image": entry.image ? new URL(entry.image, Astro.url.origin).toString() : undefined,
  "creator": {
    "@type": "Person",
    "name": "Paulus Lestyo Adhiatma"
  }
};

function getExperienceCompany(expSlug: string | null) {
  if (!expSlug) return null;
  return workExperience.find(exp => exp.slug === expSlug)?.entry.company || expSlug;
}
---

<Layout 
  title={`${entry.name} | Projects | Paulus Lestyo Adhiatma`}
  description={entry.shortDescription}
  ogImage={entry.image || undefined}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(projectSchema)} />
  <article class="pt-28 pb-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <!-- Back Navigation -->
        <a href="/projects" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors mb-8">
          <ArrowLeft class="h-4 w-4" />
          Back to Projects
        </a>

        <!-- Hero Image -->
        {entry.image && (
          <div class="relative overflow-hidden rounded-xl mb-8 shadow-lg">
            <Image
              src={entry.image}
              alt={entry.name}
              width={1200}
              height={600}
              class="w-full h-64 md:h-96 object-cover"
            />
          </div>
        )}

        <!-- Header -->
        <header class="mb-8">
          <h1 class="text-3xl md:text-4xl font-bold mb-4">{entry.name}</h1>
          <p class="text-lg text-muted-foreground mb-6">{entry.shortDescription}</p>
          
          <!-- Tech Stack -->
          <div class="flex flex-wrap gap-2 mb-4">
            {entry.techstack.map((tech) => (
              <Badge variant="outline">{tech}</Badge>
            ))}
          </div>

          <!-- Experience Link -->
          {entry.experience && (
            <div class="text-sm text-muted-foreground bg-muted/40 px-4 py-2 rounded-lg border border-border/30 inline-block">
              💼 Dibuat saat bekerja di: <span class="font-medium text-foreground">{
                getExperienceCompany(entry.experience)
              }</span>
            </div>
          )}
        </header>

        <!-- Content -->
        <div class="prose prose-lg dark:prose-invert max-w-none text-muted-foreground">
          <DocumentRenderer document={entry.content} />
        </div>
      </div>
    </div>
  </article>
  <Footer />
</Layout>
